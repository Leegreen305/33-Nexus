generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  ADMIN
}

enum ProjectStatus {
  ACTIVE
  COMPLETE
  PAUSED
}

enum PhaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  role          Role      @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      Project[] @relation("ClientProjects")
  messages      Message[] @relation("SenderMessages")
  filesUploaded File[]    @relation("UploaderFiles")
  sessions      Session[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id                  String        @id @default(cuid())
  name                String
  clientId            String
  description         String?       @db.Text
  currentPhase        Int           @default(1)
  startDate           DateTime      @default(now())
  estimatedCompletion DateTime?
  status              ProjectStatus @default(ACTIVE)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  client     User        @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  phases     Phase[]
  milestones Milestone[]
  messages   Message[]
  files      File[]
  invoices   Invoice[]
}

model Phase {
  id                  String      @id @default(cuid())
  projectId           String
  phaseNumber         Int
  phaseName           String
  status              PhaseStatus @default(PENDING)
  completionPercentage Int        @default(0)
  notes               String?     @db.Text
  startDate           DateTime?
  completionDate      DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestones Milestone[]
  files      File[]

  @@unique([projectId, phaseNumber])
}

model Milestone {
  id          String   @id @default(cuid())
  projectId   String
  phaseId     String?
  title       String
  description String?  @db.Text
  createdAt   DateTime @default(now())
  createdBy   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase   Phase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)
}

model Message {
  id        String   @id @default(cuid())
  projectId String
  senderId  String
  content   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender  User    @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model File {
  id         String   @id @default(cuid())
  projectId  String
  phaseId    String?
  fileName   String
  fileUrl    String
  fileSize   Int?
  uploadedBy String
  uploadedAt DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase      Phase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  uploader   User    @relation("UploaderFiles", fields: [uploadedBy], references: [id], onDelete: Cascade)
}

model Invoice {
  id         String        @id @default(cuid())
  projectId  String
  clientId   String
  amount     Float
  status     InvoiceStatus @default(PENDING)
  dueDate    DateTime
  paidDate   DateTime?
  invoiceUrl String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
